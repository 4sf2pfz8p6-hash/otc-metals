        <div class="step"><div class="step-num">3</div>Подтверждение</div>
        <div class="step"><div class="step-num">4</div>Раскрытие</div>
      </div>
      <div class="neg-body">
        <div class="neg-item"><div class="ni-label">Цена</div><div class="ni-value">9 150 руб/г</div></div>
        <div class="neg-item"><div class="ni-label">Объём</div><div class="ni-value">15 кг</div></div>
        <div class="neg-item"><div class="ni-label">Срок</div><div class="ni-value">3 рабочих дня</div></div>
        <div class="neg-item"><div class="ni-label">Оплата</div><div class="ni-value">Предоплата</div></div>
        <div class="neg-item"><div class="ni-label">Доставка</div><div class="ni-value">Самовывоз</div></div>
      </div>
      <div class="neg-actions">
        <button class="btn btn-green" onclick="confirmNeg(1)">Подтвердить условия</button>
        <button class="btn btn-ghost" onclick="">Предложить изменения</button>
        <button class="btn btn-red" onclick="">Отклонить</button>
      </div>
    </div>
    <div class="neg-card">
      <div class="neg-header">
        <div>
          <div class="neg-title">Серебро 999.9 · Покупка</div>
          <div style="font-size:11px;color:var(--text3);margin-top:3px">Аффинажный завод · Рейтинг 100% · Сделок 312 · Начато 13:50</div>
        </div>
        <span class="status-badge s-active">Ваш ход</span>
      </div>
      <div class="steps">
        <div class="step done"><div class="step-num">✓</div>Интерес</div>
        <div class="step done"><div class="step-num">✓</div>Согласование</div>
        <div class="step active"><div class="step-num">3</div>Подтверждение</div>
        <div class="step"><div class="step-num">4</div>Раскрытие</div>
      </div>
      <div class="neg-body">
        <div class="neg-item"><div class="ni-label">Цена</div><div class="ni-value">101.2 руб/г</div></div>
        <div class="neg-item"><div class="ni-label">Объём</div><div class="ni-value">200 кг</div></div>
        <div class="neg-item"><div class="ni-label">Срок</div><div class="ni-value">5 рабочих дней</div></div>
        <div class="neg-item"><div class="ni-label">Оплата</div><div class="ni-value">По факту</div></div>
        <div class="neg-item"><div class="ni-label">Доставка</div><div class="ni-value">Доставка продавца</div></div>
      </div>
      <div class="neg-actions">
        <button class="btn btn-gold" onclick="confirmNeg(2)">Раскрыть контрагента</button>
        <button class="btn btn-ghost" onclick="">Отклонить</button>
      </div>
    </div>
  </div>

  <!-- PROFILE PAGE -->
  <div class="page" id="page-profile">
    <div class="page-header">
      <div><div class="page-title">Профиль компании</div></div>
      <button class="btn btn-ghost" onclick="logout()">Выйти</button>
    </div>
    <div class="profile-grid">
      <div class="profile-card">
        <div class="profile-avatar" id="p-avatar">ЗТ</div>
        <div class="profile-company" id="p-company">ООО Золото-Трейд</div>
        <div class="profile-type" id="p-type">Дилер</div>
        <div class="ver-badge">✓ Верифицирован</div>
        <div class="profile-stats">
          <div class="ps-item"><div class="ps-label">Рейтинг</div><div class="ps-value" style="color:var(--green)">96%</div></div>
          <div class="ps-item"><div class="ps-label">Сделок</div><div class="ps-value">87</div></div>
          <div class="ps-item"><div class="ps-label">Завершено</div><div class="ps-value">84</div></div>
          <div class="ps-item"><div class="ps-label">Отменено</div><div class="ps-value" style="color:var(--red)">3</div></div>
        </div>
      </div>
      <div>
        <div class="profile-card" style="margin-bottom:16px">
          <div style="font-size:13px;font-weight:600;margin-bottom:16px">Данные компании</div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px">
            <div class="form-group"><label class="form-label">Название</label><input class="form-input" id="pf-company" value="ООО Золото-Трейд"></div>
            <div class="form-group"><label class="form-label">ИНН</label><input class="form-input" value="7701234567"></div>
            <div class="form-group"><label class="form-label">Контакт</label><input class="form-input" value="Иванов Иван Иванович"></div>
            <div class="form-group"><label class="form-label">Телефон</label><input class="form-input" value="+7 (999) 123-45-67"></div>
            <div class="form-group"><label class="form-label">Email</label><input class="form-input" value="info@zoloto-trade.ru"></div>
            <div class="form-group"><label class="form-label">Регион</label>
              <select class="form-select"><option>Москва</option><option>Санкт-Петербург</option><option>Екатеринбург</option></select>
            </div>
          </div>
          <div style="margin-top:16px;display:flex;justify-content:flex-end">
            <button class="btn btn-gold" onclick="saveProfile()">Сохранить изменения</button>
          </div>
        </div>
        <div class="profile-card">
          <div style="font-size:13px;font-weight:600;margin-bottom:14px">Скорость ответа</div>
          <div style="display:flex;align-items:center;gap:14px">
            <div style="font-family:'IBM Plex Mono',monospace;font-size:28px;font-weight:500;color:var(--green)">1.8ч</div>
            <div style="flex:1">
              <div style="font-size:12px;color:var(--text2);margin-bottom:6px">Среднее время ответа на запросы</div>
              <div style="background:var(--bg4);border-radius:3px;height:6px">
                <div style="width:75%;height:100%;background:var(--green);border-radius:3px"></div>
              </div>
              <div style="font-size:11px;color:var(--text3);margin-top:4px">Лучше чем 75% участников</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

</main>
</div>

<!-- CREATE MODAL -->
<div class="modal-overlay" id="modal-create">
  <div class="modal">
    <div class="modal-title">Новое предложение</div>
    <div class="modal-sub">Будет видно только верифицированным участникам</div>
    <div class="form-row">
      <div class="form-group"><label class="form-label">Металл</label>
        <select class="form-select" id="n-metal" onchange="updatePurity()">
          <option value="gold">Золото</option><option value="silver">Серебро</option>
          <option value="platinum">Платина</option><option value="palladium">Палладий</option>
        </select>
      </div>
      <div class="form-group"><label class="form-label">Тип</label>
        <select class="form-select" id="n-type">
          <option value="sell">Продажа</option><option value="buy">Покупка</option>
        </select>
      </div>
    </div>
    <div class="form-row">
      <div class="form-group"><label class="form-label">Проба</label>
        <select class="form-select" id="n-purity">
          <option>999.9</option><option>958</option><option>916</option>
          <option>900</option><option>850</option><option>750</option><option>585</option>
        </select>
      </div>
      <div class="form-group"><label class="form-label">Тип товара</label>
        <select class="form-select" id="n-form" onchange="toggleDelivery()">
          <option value="scrap">Лом</option><option value="pure">Чистый металл</option>
        </select>
      </div>
    </div>
    <div class="form-row" id="delivery-row" style="display:none">
      <div class="form-group"><label class="form-label">Форма поставки</label>
        <select class="form-select" id="n-delivery">
          <option>Слитки</option><option>Гранулы</option>
        </select>
      </div>
      <div></div>
    </div>
    <div class="form-row">
      <div class="form-group"><label class="form-label">Цена (руб/грамм)</label>
        <input class="form-input" type="number" id="n-price" placeholder="9 150">
      </div>
      <div class="form-group"><label class="form-label">Объём (кг)</label>
        <input class="form-input" type="number" id="n-volume" placeholder="10">
      </div>
    </div>
    <div class="form-row">
      <div class="form-group"><label class="form-label">Регион</label>
        <select class="form-select" id="n-region">
          <option>Москва</option><option>Санкт-Петербург</option>
          <option>Екатеринбург</option><option>Новосибирск</option><option>Казань</option>
        </select>
      </div>
      <div class="form-group"><label class="form-label">НДС</label>
        <select class="form-select" id="n-vat">
          <option>С НДС 20%</option><option>Без НДС</option>
        </select>
      </div>
    </div>
    <div class="form-row">
      <div class="form-group"><label class="form-label">Срочность</label>
        <select class="form-select" id="n-urgency">
          <option>Обычная</option><option>Срочно (24 часа)</option><option>Очень срочно (сегодня)</option>
        </select>
      </div>
      <div></div>
    </div>
    <div class="form-row full">
      <div class="form-group"><label class="form-label">Комментарий (необязательно)</label>
        <textarea class="form-input form-textarea" id="n-comment" placeholder="Условия оплаты, особые требования..."></textarea>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('modal-create')">Отмена</button>
      <button class="btn btn-gold" onclick="submitOffer()">Разместить</button>
    </div>
  </div>
</div>

<!-- INTEREST MODAL -->
<div class="modal-overlay" id="modal-interest">
  <div class="modal">
    <div class="modal-title" id="int-title">Проявить интерес</div>
    <div class="modal-sub">Анонимное предложение · Компания верифицирована</div>
    <div class="int-detail" id="int-detail"></div>
    <div class="int-note">После взаимного подтверждения обеим сторонам будут раскрыты данные компании-контрагента. Сделка заключается самостоятельно вне платформы.</div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('modal-interest')">Отмена</button>
      <button class="btn btn-gold" onclick="confirmInterest()">Подтвердить интерес</button>
    </div>
  </div>
</div>

<!-- CONTACT REVEAL MODAL -->
<div class="modal-overlay" id="modal-reveal">
  <div class="modal">
    <div class="modal-title" style="color:var(--green)">✓ Сделка согласована</div>
    <div class="modal-sub">Обе стороны подтвердили условия. Раскрываем контрагента.</div>
    <div style="background:var(--bg3);border:1px solid var(--border2);border-radius:var(--radius);padding:20px;margin-bottom:20px">
      <div style="font-size:16px;font-weight:600;margin-bottom:4px" id="reveal-company">ООО АффинажГрупп</div>
      <div style="font-size:12px;color:var(--text3);margin-bottom:16px">Аффинажный завод · Рейтинг 100% · Сделок 312</div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
        <div><div class="di-label">Контакт</div><div style="font-size:13px;font-weight:500">Петров Сергей Иванович</div></div>
        <div><div class="di-label">Телефон</div><div style="font-family:'IBM Plex Mono',monospace;font-size:14px;font-weight:500;color:var(--gold2)">+7 (495) 123-45-67</div></div>
        <div><div class="di-label">Email</div><div style="font-size:13px">info@affinaj.ru</div></div>
        <div><div class="di-label">Регион</div><div style="font-size:13px">Москва</div></div>
      </div>
    </div>
    <div style="background:var(--green-dim);border:1px solid rgba(76,175,130,0.2);border-radius:var(--radius);padding:12px;font-size:12px;color:var(--text2);line-height:1.7">
      Дальнейшее оформление сделки происходит напрямую между компаниями вне платформы. После завершения просим оценить контрагента.
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('modal-reveal')">Закрыть</button>
      <button class="btn btn-gold" onclick="closeModal('modal-reveal')">Понятно, спасибо</button>
    </div>
  </div>
</div>

<!-- NOTIFICATION -->
<div class="notif" id="notif"><div class="notif-title" id="notif-title">✓ Готово</div><div id="notif-text"></div></div>

<script>
const METALS = {
  gold:     {label:'Золото',    purity:'999.9', code:'XAU', icon:'Au', cls:'i-gold'},
  silver:   {label:'Серебро',   purity:'999.9', code:'XAG', icon:'Ag', cls:'i-silver'},
  platinum: {label:'Платина',   purity:'999.5', code:'XPT', icon:'Pt', cls:'i-platinum'},
  palladium:{label:'Палладий',  purity:'999.5', code:'XPD', icon:'Pd', cls:'i-palladium'},
};
const PURITIES = {
  gold:['999.9','958','916','900','850','750','585','Лом'],
  silver:['999','960','925','875','800','Лом'],
  platinum:['999.5','Лом платины'],
  palladium:['999.5'],
};

let offers = [
  {id:1,metal:'gold',type:'sell',price:9150,volume:15,region:'Москва',rating:98,purity:'999.9',form:'pure',time:'14:28'},
  {id:2,metal:'gold',type:'buy',price:9155,volume:8,region:'Санкт-Петербург',rating:95,purity:'999.9',form:'pure',time:'14:31'},
  {id:3,metal:'silver',type:'sell',price:101.5,volume:120,region:'Москва',rating:100,purity:'999.9',form:'scrap',time:'14:20'},
  {id:4,metal:'gold',type:'sell',price:9148,volume:3,region:'Екатеринбург',rating:87,purity:'750',form:'scrap',time:'14:15'},
  {id:5,metal:'platinum',type:'buy',price:3245,volume:2,region:'Москва',rating:92,purity:'999.5',form:'pure',time:'14:10'},
  {id:6,metal:'gold',type:'buy',price:9152,volume:25,region:'Москва',rating:99,purity:'999.9',form:'pure',time:'14:05'},
  {id:7,metal:'palladium',type:'sell',price:5820,volume:1.5,region:'Санкт-Петербург',rating:91,purity:'999.5',form:'pure',time:'13:58'},
  {id:8,metal:'silver',type:'buy',price:101.2,volume:500,region:'Екатеринбург',rating:96,purity:'999',form:'scrap',time:'13:50'},
  {id:9,metal:'platinum',type:'sell',price:3238,volume:5,region:'Москва',rating:88,purity:'999.5',form:'pure',time:'13:45'},
  {id:10,metal:'gold',type:'sell',price:9160,volume:50,region:'Новосибирск',rating:94,purity:'999.9',form:'pure',time:'13:40'},
  {id:11,metal:'gold',type:'buy',price:9145,volume:10,region:'Казань',rating:90,purity:'585',form:'scrap',time:'13:30'},
  {id:12,metal:'silver',type:'sell',price:101.8,volume:80,region:'Москва',rating:97,purity:'925',form:'scrap',time:'13:20'},
  {id:13,metal:'platinum',type:'buy',price:3242,volume:3,region:'Санкт-Петербург',rating:85,purity:'999.5',form:'pure',time:'13:10'},
  {id:14,metal:'gold',type:'sell',price:9155,volume:20,region:'Москва',rating:99,purity:'999.9',form:'pure',time:'13:00'},
  {id:15,metal:'palladium',type:'buy',price:5800,volume:2,region:'Москва',rating:93,purity:'999.5',form:'pure',time:'12:50'},
];

let activeFilter = {metal:'',type:'',region:'',volume:'',purity:''};
let currentUser = null;

// AUTH
function showAuth() { document.getElementById('auth-page').classList.add('open'); }
function hideAuth() { document.getElementById('auth-page').classList.remove('open'); }

function switchAuthTab(tab, el) {
  document.querySelectorAll('.auth-tab').forEach(t=>t.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('tab-login').style.display = tab==='login'?'block':'none';
  document.getElementById('tab-reg').style.display = tab==='reg'?'block':'none';
}

function doLogin() {
  const email = document.getElementById('login-email').value;
  if (!email) { showNotif('Ошибка','Введите email','red'); return; }
  currentUser = {name:'ООО Золото-Трейд', type:'Дилер', email};
  hideAuth();
  applyUserUI();
  showNotif('Добро пожаловать','Вы вошли в систему');
}

function doRegister() {
  const company = document.getElementById('reg-company').value;
  if (!company) { showNotif('Ошибка','Заполните название компании','red'); return; }
  hideAuth();
  showNotif('Заявка отправлена','После проверки документов вы получите доступ');
}

function logout() {
  currentUser = null;
  document.getElementById('sidebar-user').style.display = 'none';
  document.getElementById('header-nav').innerHTML = `
    <button class="btn btn-ghost" onclick="showAuth()">Войти</button>
    <button class="btn btn-gold" onclick="showCreate()">+ Разместить предложение</button>`;
  showPage('market');
}

function applyUserUI() {
  if (!currentUser) return;
  document.getElementById('sidebar-user').style.display = 'block';
  document.getElementById('u-name').textContent = currentUser.name;
  document.getElementById('u-type').textContent = currentUser.type;
  document.getElementById('header-nav').innerHTML = `
    <button class="btn btn-ghost" onclick="showPage('profile')">Мой профиль</button>
    <button class="btn btn-gold" onclick="showCreate()">+ Новое предложение</button>`;
}

// NAVIGATION
function showPage(name, sidebarEl) {
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.getElementById('page-'+name).classList.add('active');
  if (sidebarEl) {
    document.querySelectorAll('.sidebar-item').forEach(i=>i.classList.remove('active'));
    sidebarEl.classList.add('active');
  }
}

// FILTERS
function applyFilters() {
  activeFilter.metal = document.getElementById('f-metal').value;
  activeFilter.region = document.getElementById('f-region').value;
  activeFilter.volume = document.getElementById('f-volume').value;
  activeFilter.purity = document.getElementById('f-purity').value;
  let list = offers.filter(o=>{
    if (activeFilter.metal && o.metal!==activeFilter.metal) return false;
    if (activeFilter.type && o.type!==activeFilter.type) return false;
    if (activeFilter.region && o.region!==activeFilter.region) return false;
    if (activeFilter.volume && o.volume<parseFloat(activeFilter.volume)) return false;
    if (activeFilter.purity && o.purity!==activeFilter.purity) return false;
    return true;
  });
  renderRows(list);
}

function setChip(t) {
  activeFilter.type = t==='all'?'':t;
  document.querySelectorAll('.chip').forEach(c=>c.className='chip');
  if(t==='all') document.getElementById('chip-all').classList.add('c-all');
  if(t==='buy') document.getElementById('chip-buy').classList.add('c-buy');
  if(t==='sell') document.getElementById('chip-sell').classList.add('c-sell');
  applyFilters();
}

function sidebarMetal(metal, el) {
  document.querySelectorAll('.sidebar-item').forEach(i=>i.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('f-metal').value = metal;
  showPage('market');
  applyFilters();
}

function sidebarType(type, el) {
  document.querySelectorAll('.sidebar-item').forEach(i=>i.classList.remove('active'));
  el.classList.add('active');
  showPage('market');
  setChip(type);
}

function formatP(p,m) {
  if(m==='silver'||m==='platinum'||m==='palladium')
    return p.toLocaleString('ru-RU',{minimumFractionDigits:1,maximumFractionDigits:1});
  return p.toLocaleString('ru-RU');
}

function renderRows(list) {
  const tb = document.getElementById('table-body');
  if(!list.length){
    tb.innerHTML=`<div class="empty-state"><div class="empty-icon">◈</div><div class="empty-text">Нет предложений по выбранным фильтрам</div></div>`;
    return;
  }
  tb.innerHTML = list.map(o=>{
    const m=METALS[o.metal]; const isBuy=o.type==='buy';
    return `<div class="table-row" onclick="showInterest(${o.id})">
      <div class="metal-cell"><div class="metal-icon ${m.cls}">${m.icon}</div><div><div class="metal-name">${m.label}</div><div class="metal-purity">${o.purity||m.purity}</div></div></div>
      <div><span class="badge ${isBuy?'b-buy':'b-sell'}">${isBuy?'КУПЛЯ':'ПРОД'}</span></div>
      <div><div class="price-cell">${formatP(o.price,o.metal)}</div><div class="price-unit">руб/г</div></div>
      <div><div class="vol-cell">${o.volume} <span class="vol-unit">кг</span></div><div style="font-size:10px;color:var(--text3);font-family:'IBM Plex Mono',monospace">${(o.volume*1000).toLocaleString('ru-RU')} г</div></div>
      <div class="region-cell">${o.region}</div>
      <div class="rating-cell"><div class="r-bar"><div class="r-fill" style="width:${o.rating}%"></div></div><span class="r-text">${o.rating}%</span></div>
      <div class="time-cell">${o.time}</div>
      <div class="action-cell"><button class="btn-interest" onclick="event.stopPropagation();showInterest(${o.id})">Интересно →</button></div>
    </div>`;
  }).join('');
  document.getElementById('s-total').textContent = list.length;
}

// CREATE OFFER
function showCreate() { document.getElementById('modal-create').classList.add('open'); }

function updatePurity() {
  const metal = document.getElementById('n-metal').value;
  const sel = document.getElementById('n-purity');
  sel.innerHTML = (PURITIES[metal]||['999.9']).map(p=>`<option>${p}</option>`).join('');
}

function toggleDelivery() {
  const v = document.getElementById('n-form').value;
  document.getElementById('delivery-row').style.display = v==='pure'?'grid':'none';
}

function submitOffer() {
  const metal=document.getElementById('n-metal').value;
  const type=document.getElementById('n-type').value;
  const price=parseFloat(document.getElementById('n-price').value);
  const volume=parseFloat(document.getElementById('n-volume').value);
  const region=document.getElementById('n-region').value;
  const purity=document.getElementById('n-purity').value;
  const form=document.getElementById('n-form').value;
  if(!price||!volume){showNotif('Ошибка','Укажите цену и объём','red');return;}
  const now=new Date();
  const time=now.getHours().toString().padStart(2,'0')+':'+now.getMinutes().toString().padStart(2,'0');
  const newO={id:Date.now(),metal,type,price,volume,region,purity,form,rating:Math.floor(Math.random()*10)+88,time};
  offers.unshift(newO);
  closeModal('modal-create');
  applyFilters();
  setTimeout(()=>{const r=document.querySelectorAll('.table-row');if(r[0])r[0].classList.add('highlight');},50);
  document.getElementById('n-price').value='';
  document.getElementById('n-volume').value='';
  document.getElementById('n-comment').value='';
  showNotif('Предложение размещено','Оно появилось в рынке');
}

// INTEREST
function showInterest(id) {
  const o=offers.find(x=>x.id===id); if(!o)return;
  const m=METALS[o.metal]; const isBuy=o.type==='buy';
  document.getElementById('int-title').textContent=isBuy?'Предложить продажу':'Запросить покупку';
  document.getElementById('int-detail').innerHTML=`
    <div><div class="di-label">Металл</div><div class="di-value">${m.label} ${o.purity||m.purity}</div></div>
    <div><div class="di-label">Тип</div><div class="di-value">${isBuy?'Покупка':'Продажа'}</div></div>
    <div><div class="di-label">Цена</div><div class="di-value">${formatP(o.price,o.metal)} руб/г</div></div>
    <div><div class="di-label">Объём</div><div class="di-value">${o.volume} кг</div></div>
    <div><div class="di-label">Регион</div><div class="di-value">${o.region}</div></div>
    <div><div class="di-label">Участник</div><div class="di-value" style="font-size:12px">Рейтинг ${o.rating}%</div></div>`;
  document.getElementById('modal-interest').classList.add('open');
}

function confirmInterest() {
  closeModal('modal-interest');
  showNotif('Интерес отправлен','Ожидайте подтверждения от контрагента');
}

function confirmNeg(id) {
  closeModal('modal-interest');
  document.getElementById('modal-reveal').classList.add('open');
}

// MY OFFERS
function withdrawOffer(id) {
  if(confirm('Снять предложение с рынка?')){
    showNotif('Предложение снято','Оно удалено из рынка');
  }
}
function editOffer(id) { showCreate(); }

function saveProfile() {
  const name=document.getElementById('pf-company').value;
  document.getElementById('u-name').textContent=name;
  showNotif('Профиль сохранён','Данные обновлены');
}

// MODAL
function closeModal(id){document.getElementById(id).classList.remove('open');}
document.querySelectorAll('.modal-overlay').forEach(o=>{
  o.addEventListener('click',e=>{if(e.target===o)o.classList.remove('open');});
});

// NOTIFICATION
function showNotif(title,text,type) {
  const n=document.getElementById('notif');
  const t=document.getElementById('notif-title');
  const tx=document.getElementById('notif-text');
  t.textContent=(type==='red'?'✗ ':' ✓ ')+title;
  t.style.color=type==='red'?'var(--red)':'var(--green)';
  n.style.borderColor=type==='red'?'var(--red)':'var(--green)';
  tx.textContent=text;
  n.classList.add('show');
  setTimeout(()=>n.classList.remove('show'),3500);
}

// CLOCK
setInterval(()=>{
  const n=new Date();
  document.getElementById('clock').textContent=
    n.getHours().toString().padStart(2,'0')+':'+
    n.getMinutes().toString().padStart(2,'0')+':'+
    n.getSeconds().toString().padStart(2,'0');
},1000);

// API LOAD (подключается к реальному /offers когда есть бэкенд)
async function loadOffers() {
  try {
    const res = await fetch('/offers');
    if(!res.ok) throw new Error('no api');
    const data = await res.json();
    if(data && data.length > 0) {
      offers = data.map(o=>({
        id: o.offer_id, metal: o.metal, type: o.side,
        price: parseFloat(o.price_rub_per_gram),
        volume: parseFloat(o.volume_grams)/1000,
        region: o.region||'—', rating: o.rating||90,
        purity: o.purity||'999.9', form: o.metal_form||'pure',
        time: new Date(o.created_at).toLocaleTimeString('ru-RU',{hour:'2-digit',minute:'2-digit'})
      }));
    }
  } catch(e) { /* используем моковые данные */ }
  applyFilters();
}

// INIT
loadOffers();
</script>
</body>
</html>
