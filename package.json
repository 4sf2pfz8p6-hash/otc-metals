{
  "name": "otc-api",
  "version": "1.0.0",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc",
    "start": "node scripts/migrate.mjs && node dist/server.js",
    "dev": "ts-node server.ts",
